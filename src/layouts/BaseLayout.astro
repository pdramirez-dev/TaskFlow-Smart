---
import Header from "../components/Header";
import Footer from "../components/Footer";
import { withBasePath } from "../lib/paths";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const {
  title,
  description,
  path = ""
} = Astro.props;

const canonical = new URL(withBasePath(path), Astro.site);
---

<!doctype html>
<html lang="en" class="page-grid">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" type="image/svg+xml" href={withBasePath("/favicon.svg")} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen antialiased">
    <div class="mx-auto flex min-h-screen w-full max-w-[100rem] flex-col px-3 sm:px-4 lg:px-5 xl:px-6">
      <Header />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
