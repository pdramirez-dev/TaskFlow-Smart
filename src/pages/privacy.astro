---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy Policy | TaskFlow Smart"
  description="Privacy policy for TaskFlow Smart."
  path="/privacy"
>
  <section class="py-14 sm:py-20">
    <div class="glass-panel mx-auto max-w-4xl rounded-[2.5rem] p-8 sm:p-12">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-700">Privacy Policy</p>
      <h1 class="section-title mt-4 text-4xl font-bold text-slate-950 sm:text-5xl">TaskFlow Smart</h1>
      <p class="mt-4 text-sm text-slate-500">Effective date: April 1, 2026</p>

      <div class="mt-10 space-y-8 text-base leading-8 text-slate-600">
        <section>
          <h2 class="font-display text-2xl font-bold text-slate-950">Information we collect</h2>
          <p class="mt-3">
            TaskFlow Smart may collect basic contact information you provide when you request
            support, along with anonymized diagnostic data needed to maintain app quality and
            performance.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-slate-950">How we use information</h2>
          <p class="mt-3">
            Information is used to operate the app, respond to support inquiries, improve product
            stability and understand high-level usage patterns.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-slate-950">Data sharing</h2>
          <p class="mt-3">
            We do not sell personal information. Data is only shared with service providers when
            necessary to host infrastructure, deliver app functionality or comply with legal
            obligations.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-slate-950">Your choices</h2>
          <p class="mt-3">
            You can contact us to request access, correction or deletion of your personal data,
            subject to applicable law.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-slate-950">Contact</h2>
          <p class="mt-3">
            For privacy questions, email
            <a class="font-semibold text-brand-700" href="mailto:privacy@taskflowsmart.app">
              {" "}privacy@taskflowsmart.app
            </a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
